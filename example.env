# --- Gemini (генерация изображений) ---
GEMINI_API_KEY="GEMINI_API_KEY"
PROXY_URL="PROXY_URL"
GEMINI_MODEL="gemini-3-pro-image-preview"
GEMINI_TEMPERATURE=0.7
LAYOUT_PATH="Макет-2-1.jpg"

# --- VK (сообщество) ---
VK_GROUP_TOKEN=VK_GROUP_TOKEN
VK_GROUP_ID=VK_GROUP_ID
VK_API_VERSION=5.199

# (опционально, для другого функционала)
VK_ACC_TOKEN=VK_ACC_TOKEN
VK_ACC_USER_ID=VK_ACC_USER_ID
GIGACHAT_ID=GIGACHAT_ID
GIGACHAT_API_KEY=GIGACHAT_API_KEY

# --- Инфраструктура (постоянный стек) ---
DATABASE_URL=postgresql+psycopg://vkaudit:vkaudit@localhost:15433/vkaudit
RABBITMQ_URL=amqp://guest:guest@localhost:5673/
RABBITMQ_JOBS_QUEUE=vk_design_jobs
RABBITMQ_RESULTS_QUEUE=vk_design_results

# --- Хранилище медиа ---
MEDIA_DIR=media

# --- Поллер (этап 1) ---
TRIGGER_KEYWORD=Начать
HISTORY_LIMIT=50
POLL_WAIT_SECONDS=25
POLL_ACK_DELAY_SECONDS=2
ACK_MESSAGE="Принял заявку в работу — скоро пришлю результат 🙌"

# --- Воркер (этап 2) ---
WORKER_REPLY_MESSAGE="Готово! Вот ваш дизайн оформления группы 🎨"
